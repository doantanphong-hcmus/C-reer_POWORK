NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL="postgresql://powork_user:powork_pass@localhost:5432/powork_db"

# JWT
JWT_SECRET=your_super_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# MinIO (Object Storage cho file bài nộp)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=powork_minio_admin
MINIO_SECRET_KEY=powork_minio_secret_123
MINIO_BUCKET=powork-submissions
MINIO_PRESIGNED_EXPIRY=300

# ClamAV (quét virus file nộp)
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# SMTP (gửi email xác nhận nộp bài)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="POWORK <no-reply@powork.vn>"
