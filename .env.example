# ==============================================================================
# TÀI LIỆU BIẾN MÔI TRƯỜNG DÀNH CHO TOÀN BỘ DỰ ÁN POWORK (ROOT)
# Hướng dẫn: Copy file này thành `.env` để chạy với Docker Compose ở thư mục gốc.
# ==============================================================================

# --- [1] CẤU HÌNH POSTGRESQL DATABASE ---
POSTGRES_USER=powork_user
POSTGRES_PASSWORD=powork_pass
POSTGRES_DB=powork_db

# --- [2] CẤU HÌNH BACKEND API (Node.js) ---
PORT=3001
# Chuỗi kết nối Database (Dành cho Docker, host là `postgres`)
DATABASE_URL="postgresql://powork_user:powork_pass@postgres:5432/powork_db"
# Secret Key để mã hóa JWT Token
JWT_SECRET="powork_super_secret_dev_2026"
JWT_EXPIRES_IN="7d"

# --- [3] CẤU HÌNH FRONTEND (Next.js) ---
# Địa chỉ API dùng để Frontend gọi từ Client-side (Browser)
NEXT_PUBLIC_API_URL=http://localhost:3001
# Địa chỉ API dùng để Frontend gọi từ Server-side (SSR trong Docker)
INTERNAL_API_URL=http://backend:3001

# --- [4] CẤU HÌNH MINIO (STORAGE) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=powork_minio_admin
MINIO_SECRET_KEY=powork_minio_secret_123
MINIO_BUCKET_NAME=powork-submissions

# --- [5] CẤU HÌNH CLAMAV (DIỆT VIRUS) ---
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# --- [6] CẤU HÌNH SMTP (GỬI EMAIL) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
